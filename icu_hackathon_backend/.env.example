SERVER_PORT=4000

LIVEKIT_URL=wss://your-livekit-domain
LIVEKIT_API_KEY=your_livekit_api_key
LIVEKIT_API_SECRET=your_livekit_api_secret

SARVAM_API_KEY=your_sarvam_api_key
SARVAM_STT_URL=https://api.sarvam.ai/speech-to-text
SARVAM_TTS_URL=https://api.sarvam.ai/text-to-speech
SARVAM_VOICE=anushka
SARVAM_VOICE_FEMALE=anushka
SARVAM_FORCE_FEMALE=true

GROQ_API_KEY=your_groq_api_key
GROQ_MODEL=llama-3.3-70b-versatile

SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
SUPABASE_ANON_KEY=your_supabase_anon_key
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=your_supabase_publishable_key

FORECAST_ENABLED=true
FORECAST_NEXT_URL=http://localhost:8080/api/v1/forecast/next
FORECAST_HEALTH_URL=http://localhost:8080/health
FORECAST_REQUEST_TIMEOUT_MS=3000
PROJECTION_FORECAST_CONCURRENCY=6
PROJECTION_RETRY_BACKOFF_MS=140